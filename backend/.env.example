# Server
PORT=5000
NODE_ENV=development

# Auth
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Database (SQLite file path, relative to backend/)
DB_STORAGE=./data/database.sqlite

# Business rules
OVERDUE_DAYS=5

# Initial admin account (created by `npm run seed`)
ADMIN_NAME=Society Admin
ADMIN_EMAIL=admin@society.com
ADMIN_PASSWORD=Admin@123

# Email (SMTP) - works with any free tier provider e.g. Brevo, Mailtrap, Gmail App Password
# If left blank, emails are logged to the console instead of being sent (safe for local dev/grading).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Society Maintenance <no-reply@society.com>"

# Frontend URL (used in email links / CORS)
FRONTEND_URL=http://localhost:5173
